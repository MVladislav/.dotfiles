tcpdump-pcap() {
    # Check if tcpdump is installed
    command -v tcpdump >/dev/null 2>&1 || {
        echo "Error: tcpdump is not installed. Please install it and try again." >&2
        return 1
    }

    # Usage check
    if [ "$#" -lt 1 ]; then
        echo "Usage: tcpdump-pcap <interface> [output_base] [max_size_mb] [max_files]"
        echo "Example: tcpdump-pcap eth0 /tmp/capture 100 5"
        return 1
    fi

    local interface="${1}"
    local output_base="${2:-${OUTFILE:-/tmp/tcpdump}}"
    local max_size_mb="${3:-100}"  # Default: 100MB per file
    local max_files="${4:-5}"      # Default: 5 rotated files

    # Validate interface
    if ! ip link show "$interface" &>/dev/null; then
        echo "Error: Interface '$interface' not found." >&2
        return 1
    fi
    local output_dir timestamp output_file

    # Create output directory if needed
    output_dir=$(dirname "$output_base")
    if [ -n "$output_dir" ] && [ ! -d "$output_dir" ]; then
        mkdir -p "$output_dir" || { echo "Error: Cannot create directory '$output_dir'." >&2; return 1; }
    fi

    # Build output filename with timestamp
    timestamp=$(date +"%Y%m%d_%H%M%S")
    output_file="${output_base}_${timestamp}.pcap"

    # Smart capture options
    tcpdump -i "$interface" \
           -w "$output_file" \
           -s0 \
           -C "$max_size_mb" \
           -W "$max_files" \
           -U \
           -n \
           -nn \
           -q \
           -tttt \
           --immediate-mode \
           --buffer-size=1000000

    echo "Capturing on $interface -> $output_file (max $max_size_mb MB, $max_files files)"
}

