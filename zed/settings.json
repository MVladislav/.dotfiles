// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "code_lens": "on",
  "show_signature_help_after_edits": true,
  "auto_signature_help": true,
  "status_bar": {
    "experimental.show": true
  },
  "gutter": {
    "line_numbers": true
  },
  // "relative_line_numbers": "enabled",
  "show_whitespaces": "selection",
  "show_edit_predictions": true,
  "file_finder": {
    "modal_max_width": "medium"
  },
  "tab_bar": {
    "show": true
  },
  // "autosave": {
  //   "after_delay": {
  //     "milliseconds": 5000
  //   }
  // },
  // #################
  "project_panel": {
    "dock": "left",
    "auto_fold_dirs": false,
    "button": true,
    "git_status": true
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "terminal": {
    "dock": "bottom",
    "show_count_badge": true,
    "font_size": 16,
    "font_family": "Hack Nerd Font Mono",
    "line_height": {
      "custom": 1.25
    }
    // "detect_venv": {
    //   "on": {
    //     "directories": [".venv", "~/.venv"],
    //     "activate_script": "default",
    //   },
    // },
    // "env": {
    //   "EDITOR": "zed --wait",
    // },
  },
  "debugger": {
    "dock": "bottom"
  },
  "git_panel": {
    "dock": "left",
    "tree_view": true
  },
  "diff_view_style": "split",
  "session": {
    "restore_unsaved_buffers": true
  },
  "wrap_guides": [80, 130],
  "show_wrap_guides": true,
  "soft_wrap": "editor_width",
  "cursor_blink": false,
  "cursor_shape": "bar",
  "ui_font_family": "Hack Nerd Font Mono",
  "ui_font_size": 16,
  "ui_font_weight": 400,
  "buffer_font_family": "Hack Nerd Font Mono",
  "buffer_font_size": 16.0,
  "buffer_font_weight": 400,
  "buffer_line_height": {
    "custom": 1.25
  },
  "tab_size": 2,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte - No Italics",
    "dark": "Catppuccin Macchiato - No Italics"
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Macchiato"
  },
  "colorize_brackets": true,
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "errors"
  },
  // "vim_mode": true,
  "base_keymap": "VSCode",
  "use_autoclose": true,
  "current_line_highlight": "all",
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware"
  },
  "inlay_hints": {
    "enabled": true
  },
  "scrollbar": {
    "show": "auto"
  },
  "git": {
    "disable_git": false,
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true,
      "delay_ms": 200
    }
  },
  "use_on_type_format": false,
  "format_on_save": "on",
  "languages": {
    "Markdown": {
      "preferred_line_length": 130,
      "format_on_save": "on"
    },
    "SQL": {
      "formatter": "prettier"
    },
    "JSON": {
      "prettier": {
        "allowed": true,
        "parser": "json"
      }
    },
    "Shell Script": {
      "preferred_line_length": 130,
      "format_on_save": "on",
      "enable_language_server": true,
      "language_servers": ["bash-language-server"]
    },
    "Python": {
      "preferred_line_length": 130,
      "format_on_save": "on",
      "hard_tabs": true,
      "formatter": {
        "language_server": {
          "name": "ruff"
        }
      },
      "enable_language_server": true,
      "language_servers": [
        "ty",
        "ruff",
        "!basedpyright",
        "!pyrefly",
        "!pyright",
        "!pylsp"
      ]
    },
    "Rust": {
      "preferred_line_length": 130,
      "format_on_save": "on",
      "use_on_type_format": false
    },
    "JavaScript": {
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "TypeScript": {
      "preferred_line_length": 130,
      "hard_tabs": true,
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": false,
        "show_other_hints": true,
        "show_type_hints": true
      }
    }
  },
  "file_types": {
    "ansible": [
      "**/defaults/**/*",
      "**/tasks/**/*.yml",
      "**/handler/*.yml",
      "**/*_vars/**/*.yml",
      "**/roles/**/*.yml",
      "**/playbooks/**/*.yml",
      "**/*ansible*/**/*.yml",
      "**/vars/**/*.yml",
      "**/inventory/*/*"
    ],
    "Docker Compose": ["docker-compose*"],
    "Dockerfile": ["Dockerfile*"],
    "env": [".env*"],
    "Git Ignore": [".gitignore", ".dockerignore", ".gitattributes"],
    "YAML": ["*.yml", "*.yaml", ".yamllint"],
    "JSON": ["json", "jsonc", "*.code-snippets"]
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    // #############
    "**/out",
    "**/dist",
    "**/.husky",
    "**/.turbo",
    "**/.vscode-test",
    "**/.vscode",
    "**/.next",
    "**/.storybook",
    "**/.tap",
    "**/.nyc_output",
    "**/report",
    "**/node_modules"
  ],
  "auto_install_extensions": {
    "catppuccin": true,
    "catppuccin-icons": true
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "edit_predictions": {
    "provider": "none"
  },
  "disable_ai": true,
  "agent": {
    "dock": "right",
    "sidebar_side": "right",
    "default_profile": "write",
    "single_file_review": true,
    "default_model": {
      "provider": "ollama",
      "model": "ministral-3:14b"
    },
    "model_parameters": []
  },
  "language_models": {
    "ollama": {
      "api_url": "http://127.0.0.1:11434",
      "available_models": [
        {
          "name": "ministral-3:14b",
          "display_name": "ministral3",
          "max_tokens": 32768,
          "keep_alive": "5m",
          "supports_tools": true,
          "supports_thinking": false,
          "supports_images": true
        }
      ]
    }
  }
}
